{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": [
    "*.ts",
    "eslint.config.ts",
    "eleventy.config.ts",
    "src/lib/**/*.ts",
    "scripts/**/*.ts"
  ]
}
