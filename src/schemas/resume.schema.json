{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/resume/src/schemas/resume.schema.json",
  "title": "職務経歴書（Eleventy _data）",
  "description": "Eleventy + Nunjucks 用の resume グローバルデータ。JSON Resume とは別形式です。",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "page_title": { "type": "string" }
      }
    },
    "basic_info": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rows": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "name" },
                  "label": { "type": "string" },
                  "family": { "type": "string" },
                  "given": { "type": "string" }
                },
                "required": ["type", "label", "family", "given"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "birth_date" },
                  "label": { "type": "string" },
                  "birth_date": {
                    "type": "string",
                    "pattern": "^\\d{4}-(0?[1-9]|1[0-2])-(0?[1-9]|[12]\\d|3[01])$"
                  }
                },
                "required": ["type", "label", "birth_date"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "text" },
                  "label": { "type": "string" },
                  "academic_background": { "type": "string" }
                },
                "required": ["type", "label", "academic_background"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "experience" },
                  "label": { "type": "string" },
                  "experiences": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "job": { "type": "string" },
                        "duration": { "type": "string" }
                      },
                      "required": ["job", "duration"]
                    }
                  }
                },
                "required": ["type", "label", "experiences"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "certifications" },
                  "label": { "type": "string" },
                  "show_other": { "type": "boolean" },
                  "other_title": { "type": "string" },
                  "certifications": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "title": { "type": "string" },
                        "acquired_at": {
                          "type": "string",
                          "pattern": "^\\d{4}/(0?[1-9]|1[0-2])$"
                        }
                      },
                      "required": ["title"]
                    },
                    "minItems": 1
                  }
                },
                "required": ["type", "label", "certifications"]
              }
            ]
          }
        }
      },
      "required": ["rows"]
    },
    "work_history": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "companies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "period_html": { "type": "string" },
              "projects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "title": { "type": "string" },
                    "start": {
                      "type": "string",
                      "pattern": "^\\d{4}/(0?[1-9]|1[0-2])$"
                    },
                    "end": {
                      "type": "string",
                      "pattern": "^\\d{4}/(0?[1-9]|1[0-2])$"
                    },
                    "summary": { "type": "string" },
                    "role": { "type": "string" },
                    "tasks": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1
                    },
                    "environment": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1
                    },
                    "detail": { "type": "string" }
                  },
                  "required": ["title", "start", "role"]
                }
              }
            },
            "required": ["name", "period_html", "projects"]
          }
        }
      }
    },
    "footer": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
